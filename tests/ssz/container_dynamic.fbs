namespace ssz_test;

// Helper struct for fixed 32-byte arrays in tables.
struct Bytes32 {
  data:[ubyte:32];
}

// Test schema: table with mixed fixed and variable-length fields.
table DynamicContainer {
  slot:ulong;
  data:[ubyte] (ssz_max:"1048576");
  graffiti:Bytes32;
  values:[ulong] (ssz_max:"8192");
}
